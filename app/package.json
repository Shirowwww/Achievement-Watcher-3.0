{
  "private": true,
  "name": "Achievement-Watcher",
  "description": "A sexy achievement file parser with real-time notification.",
  "version": "3.0.4",
  "main": "./electron/init.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "electron .",
    "test": "node --test \"../test/*.test.js\"",
    "clean": "npm prune --omit=dev",
    "prepare": "patch-package",
    "prepare:watchdog": "cd ../watchdog && npm prune --omit=dev",
    "build": "npm run prepare:watchdog && electron-builder --config electron-builder.yml --publish never"
  },
  "author": "Anthony Beaumont",
  "license": "LGPL-3.0-only",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-context-menu": "^4.1.2",
    "patch-package": "^8.0.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@xan105/fs": "^1.2.0",
    "@xan105/ini": "^1.0.1",
    "@xan105/log": "^1.0.2",
    "7zip-bin": "^5.2.0",
    "accountpicture-ms-extractor": "^1.2.4",
    "adm-zip": "0.4.13",
    "argv-split": "^2.0.1",
    "chrome-launcher": "^0.15.1",
    "crc": "^3.8.0",
    "deepmerge": "^4.2.2",
    "electron-updater": "^6.8.9",
    "fast-glob": "^3.2.4",
    "fast-xml-parser": "^5.3.0",
    "find-up": "^4.1.0",
    "humanize-duration": "^3.25.1",
    "js-yaml": "^5.0.0",
    "lodash.omit": "^4.5.0",
    "minimist": "^1.2.5",
    "moment": "^2.29.1",
    "node-7z": "^3.0.0",
    "node-fetch": "^2.7.0",
    "node-html-parser": "^4.0.0",
    "node-unrar-js": "^2.0.2",
    "normalize-path": "^3.0.0",
    "punycode": "^2.3.1",
    "puppeteer": "^19.11.1",
    "puppeteer-extra": "^3.3.4",
    "puppeteer-extra-plugin-stealth": "^2.11.1",
    "registry-js": "^1.16.1",
    "request-zero": "^0.3.2",
    "semver": "^7.7.3",
    "sharp": "^0.35.1",
    "sound-play": "^1.1.0",
    "steam-user": "^5.2.3",
    "steamid": "^1.1.3",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "protobufjs": "7.6.4",
    "tar-fs": "2.1.4",
    "ws": "8.21.0",
    "xml2js": "$xml2js"
  },
  "config": {
    "user-agent": "Chrome/",
    "disable-gpu": false,
    "window": {
      "width": 1300,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600,
      "backgroundColor": "#1b2838",
      "frame": false,
      "icon": "resources/icon/icon.png",
      "view": "./view/app.html"
    },
    "update": {
      "github": "Shirowwww/Achievement-Watcher-3.0",
      "name": "Achievement.Watcher.Setup.exe"
    },
    "appid": "io.github.shirowwww.achievement.watcher"
  }
}
